# =============================================================================
# HomeLab DNS Manager — copy to .env and customise
#   mkdir homelab-dns-manager && cd homelab-dns-manager
#   cp .env.example .env
#   chmod 600 .env
# =============================================================================

# --- Docker image (pre-built on Docker Hub; override for Gitea/private registry) ---
# HOMELAB_DNS_IMAGE=ashiepleb/homelab-dns-manager:latest

# --- REQUIRED: generate random values (see README for commands) ---
SECRET_KEY=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME
JWT_SECRET_KEY=CHANGE_ME
CLOUDFLARE_API_TOKEN=CHANGE_ME

# --- Optional: one-time import from old favonia DDNS (leave EMPTY to protect apex site) ---
# Only add subdomains here if migrating — NOT example.com if your main site is hosted elsewhere
LEGACY_DDNS_DOMAINS=

# --- First admin account (created once on first deploy) ---
# Login: admin / password — you will be prompted to change name, email, and password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin User

# --- Web UI port on the host ---
PORT=8000

# --- DDNS ---
DDNS_INTERVAL_MINUTES=5
DDNS_PROXIED_DEFAULT=false
PUBLIC_IP_CHECK_URL=https://api.ipify.org

# --- Built-in reverse proxy (Caddy) — Let's Encrypt contact email ---
ACME_EMAIL=admin@example.com

# --- Optional ---
APP_NAME=HomeLab DNS Manager
DEBUG=false
HOST=0.0.0.0
DATABASE_URL=sqlite+aiosqlite:////app/data/homelab_dns.db
JWT_ALGORITHM=HS256
# Sessions expire after 8h; idle timeout 60m (sign in again after either)
SESSION_EXPIRE_MINUTES=480
SESSION_IDLE_MINUTES=60
JWT_EXPIRE_MINUTES=480
DOCKER_SOCKET=/var/run/docker.sock
